<div class="ea-wrap">
  <div class="ea-card">
    <div class="ea-heading">{{ section.settings.heading }}</div>
    <div class="ea-sub">{{ section.settings.subheading }}</div>

    {% form 'customer', id: 'ea-form' %}
      <input type="hidden" name="contact[tags]" value="ss26-early-access">
      <div class="ea-field">
        <label>Email address</label>
        <input type="email" name="contact[email]" placeholder="your@email.com" required />
      </div>
      <button type="submit" class="ea-btn">{{ section.settings.button_label }}</button>
      <div class="ea-note">{{ section.settings.note }}</div>
    {% endform %}
  </div>
</div>

<style>
.ea-wrap{background:#0a0a0a;display:flex;align-items:center;justify-content:center;padding:{{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;font-family:'Helvetica Neue',sans-serif}
.ea-card{width:100%;max-width:480px}
.ea-heading{font-size:11px;letter-spacing:5px;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:6px}
.ea-sub{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:36px}
.ea-field{margin-bottom:14px}
.ea-field label{display:block;font-size:8px;letter-spacing:4px;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:8px}
.ea-field input{width:100%;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:6px;padding:14px 18px;font-size:11px;letter-spacing:3px;color:#fff;outline:none;transition:border-color 0.3s ease;font-family:inherit}
.ea-field input::placeholder{color:rgba(255,255,255,0.15);letter-spacing:3px;font-size:10px}
.ea-field input:focus{border-color:rgba(179,102,255,0.4);background:rgba(255,255,255,0.05)}
.ea-btn{width:100%;margin-top:28px;padding:16px;background:transparent;border:1px solid rgba(255,255,255,0.12);border-radius:6px;color:rgba(255,255,255,0.6);font-size:9px;letter-spacing:6px;text-transform:uppercase;cursor:pointer;font-family:inherit;transition:all 0.3s ease}
.ea-btn:hover{border-color:rgba(179,102,255,0.5);color:#fff;background:rgba(179,102,255,0.06)}
.ea-note{margin-top:20px;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.12);text-align:center}
</style>

{% schema %}
{
  "name": "SS26 Early Access",
  "blocks": [],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SS26 Early Access"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Limited units — register your interest"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Request Early Access"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note",
      "default": "Strictly confidential — no spam, ever"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "SS26 Early Access"
    }
  ]
}
{% endschema %}